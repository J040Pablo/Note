{
  "expo": {
    "name": "Life Organizer",
    "slug": "life-organizer",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "scheme": "lifeorganizer",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.lifeorganizer",
      "infoPlist": {
        "NSCameraUsageDescription": "Use camera to scan QR codes and pair with Web on local network."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.example.lifeorganizer",
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "7f97a7d5-adfc-4d42-9320-1ddd6bd69eb8"
      }
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-camera",
      "expo-notifications",
      "./expo-plugins/app-widget"
    ]
  }
}
